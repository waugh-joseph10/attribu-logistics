# Django Settings - PRODUCTION
# Generate a new secret key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-KEY-IN-PRODUCTION

DEBUG=False

# Add your production domain(s) here
ALLOWED_HOSTS=attribu.io,www.attribu.io

# Database Configuration (Docker)
DB_NAME=attribu
DB_USER=postgres
DB_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
DB_HOST=db
DB_PORT=5432

# Redis Configuration (Docker)
REDIS_URL=redis://redis:6379/0

# Celery Configuration (Docker)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security Settings (for HTTPS with SSL)
# Uncomment these after you've set up SSL certificates
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True

# Optional: Email configuration for production
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
