# Django Settings - PRODUCTION
# Generate a new secret key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-KEY-IN-PRODUCTION

DEBUG=False

# Deployment image. GitHub Actions overrides this during deploy with an immutable GHCR tag.
APP_IMAGE=ghcr.io/your-github-username/attribu-logistics:main-latest

# Add your production domain(s) here
ALLOWED_HOSTS=attribu.io,www.attribu.io

# Database Configuration (Docker)
DB_NAME=attribu
DB_USER=postgres
DB_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
DB_HOST=db
DB_PORT=5432

# Redis Configuration (Docker)
REDIS_PASSWORD=CHANGE-THIS-TO-A-STRONG-RANDOM-PASSWORD

# Celery Configuration (Docker). Include the Redis password because production Redis requires auth.
REDIS_URL=redis://:CHANGE-THIS-TO-A-STRONG-RANDOM-PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE-THIS-TO-A-STRONG-RANDOM-PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE-THIS-TO-A-STRONG-RANDOM-PASSWORD@redis:6379/0

# Email configuration (required — waitlist confirmation and admin notification emails use this)
# SendGrid example (recommended):
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE-THIS-TO-YOUR-SENDGRID-API-KEY
DEFAULT_FROM_EMAIL=noreply@attribu.io
ADMIN_EMAIL=CHANGE-THIS-TO-YOUR-ADMIN-EMAIL

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
