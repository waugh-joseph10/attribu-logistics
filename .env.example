# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For local development without Docker: use localhost
# For Docker: use 'db' as the host
DB_NAME=attribu_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost  # Use 'db' for Docker
DB_PORT=5432

# Redis Configuration (for Celery - V2)
# For local development without Docker: use localhost
# For Docker: use 'redis' as the host
REDIS_URL=redis://localhost:6379/0  # Use redis://redis:6379/0 for Docker
REDIS_PASSWORD=  # Leave empty for local dev; required in production Docker setup

# Celery Configuration (V2)
CELERY_BROKER_URL=redis://localhost:6379/0  # Use redis://redis:6379/0 for Docker
CELERY_RESULT_BACKEND=redis://localhost:6379/0  # Use redis://redis:6379/0 for Docker

# Email Configuration (Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_YourApiKeyHere
DEFAULT_FROM_EMAIL=noreply@attribu.io
ADMIN_EMAIL=admin@attribu.io
