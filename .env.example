# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For local development without Docker: use localhost
# For Docker: use 'db' as the host
DB_NAME=attribu_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost  # Use 'db' for Docker
DB_PORT=5432

# Redis Configuration (for Celery - V2)
# REDIS_PASSWORD is REQUIRED in production (docker-compose.yml enforces --requirepass)
# Leave empty for local dev only
REDIS_PASSWORD=  # REQUIRED in production; empty for local dev
# Note: CELERY_BROKER_URL and CELERY_RESULT_BACKEND are automatically built from REDIS_PASSWORD in production
# For local dev without Docker, you can override:
REDIS_URL=redis://localhost:6379/0  # Local dev only
CELERY_BROKER_URL=redis://localhost:6379/0  # Local dev only
CELERY_RESULT_BACKEND=redis://localhost:6379/0  # Local dev only

# Email Configuration (Resend)
# RESEND_API_KEY is the primary method for sending emails (recommended)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_YourApiKeyHere
DEFAULT_FROM_EMAIL=noreply@attribu.io
ADMIN_EMAIL=admin@attribu.io

# Legacy SMTP settings (optional - only needed if using SMTP instead of API)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_YourApiKeyHere

# Mapbox Configuration (for map visualization)
# Public token - safe for client-side use, restrict by URL in Mapbox dashboard
# Get from https://account.mapbox.com/access-tokens/
MAPBOX_PUBLIC_TOKEN=pk.your_public_token_here

# Sentry Configuration (Optional - for error tracking and performance monitoring)
SENTRY_DSN=  # Get from https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
SENTRY_ENVIRONMENT=production  # e.g., production, staging, development
SENTRY_RELEASE=  # Automatically set to git SHA during deployment (see Makefile)
